#!/bin/sh
# Maven wrapper script for Unix/Mac/Linux/WSL
# Downloads Maven automatically on first run.

set -e

MAVEN_WRAPPER_JAR=".mvn/wrapper/maven-wrapper.jar"
MAVEN_WRAPPER_PROPERTIES=".mvn/wrapper/maven-wrapper.properties"

# --- Download wrapper jar if missing ---
if [ ! -f "$MAVEN_WRAPPER_JAR" ]; then
    WRAPPER_URL=$(grep 'wrapperUrl' "$MAVEN_WRAPPER_PROPERTIES" | cut -d'=' -f2-)
    echo "Downloading maven-wrapper.jar from $WRAPPER_URL"
    if command -v wget > /dev/null; then
        wget -q -O "$MAVEN_WRAPPER_JAR" "$WRAPPER_URL" || true
    elif command -v curl > /dev/null; then
        curl -s -o "$MAVEN_WRAPPER_JAR" "$WRAPPER_URL" || true
    fi
fi

# --- Use JAVA_HOME or system java ---
if [ -n "$JAVA_HOME" ]; then
    JAVA_CMD="$JAVA_HOME/bin/java"
else
    JAVA_CMD="java"
fi

exec "$JAVA_CMD" -jar "$MAVEN_WRAPPER_JAR" "$@"
